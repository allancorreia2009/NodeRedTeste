# ==========================================================
# Variáveis de ambiente extraídas do flows.json
# Copie este arquivo para .env (ou cole os valores no bloco
# `env: {}` do settings.js — veja instruções no final)
# ==========================================================

# --- Conexões SQL Server (nós MSSQL-CN) ---
MSSQL_WMS_SERVER=186.193.228.29          # bd_nuvem_wms — USADA EM 64 NÓS (produção)
MSSQL_PARANOA_SERVER=192.168.0.73        # dw_paranoa .73 — usada em 1 nó (ftpDatadriven)
MSSQL_ELIPSE_E3_SERVER=192.168.0.30      # paranoa_teste_renan — usada em 2 nós

# conexões cadastradas mas sem nenhum nó MSSQL referenciando no momento:
MSSQL_TESTE_DW_SERVER=186.193.228.29     # teste_dw (não usada atualmente)
MSSQL_TESTE_LUCAS_SERVER=186.193.228.29  # teste_lucas (não usada atualmente)
MSSQL_TESTE789_SERVER=186.193.228.29     # teste789 (não usada atualmente)

# --- Hosts usados em nós "http request" ---
HOST_DATAWAKE_9301=http://192.168.0.13:9301      # API produtosToInspecionar (1 nó)
HOST_DATAWAKE_7413=http://192.168.0.31:7413      # API DATAWAKE principal (24 nós: token, etiquetas, colaboradores, movimentação...)
HOST_MES=http://192.168.0.62:10001               # MES - lista OP por dispositivo (1 nó)
HOST_NODERED_LOCAL=http://192.168.0.62:1880      # chamadas ao próprio Node-RED via IP (10 nós)
HOST_NODERED_LOCAL_ALT=http://localhost:1880     # chamadas ao próprio Node-RED via localhost (8 nós)
HOST_LOCAL_KANBAN=http://localhost               # chamada sem porta explícita (1 nó)
HOST_SCRIPT_API=http://192.168.0.67:8080         # script-api demo (1 nó)
HOST_IMPRESSORA_199=http://192.168.4.199         # impressora fixa (1 nó)
HOST_IMPRESSORA_250=http://192.168.4.250         # impressora fixa (1 nó)
HOST_IMPRESSORA_253=http://72.0.0.253            # impressora fixa (1 nó)

# ==========================================================
# COMO ATIVAR NO NODE-RED (3 formas — escolha uma)
# ==========================================================
#
# 1) settings.js (mais simples, recomendado):
#    Adicione um bloco `env` no seu settings.js:
#
#    module.exports = {
#        ...
#        env: {
#            MSSQL_WMS_SERVER: "186.193.228.29",
#            HOST_DATAWAKE_7413: "http://192.168.0.31:7413",
#            // ... resto das variáveis acima
#        }
#    }
#
# 2) Variáveis de ambiente do sistema operacional / serviço:
#    Se roda como serviço systemd, adicione no arquivo de unit:
#      Environment="MSSQL_WMS_SERVER=186.193.228.29"
#    Ou exporte antes de "node-red" no terminal/script de start.
#
# 3) Environment Variables da própria aba/flow no editor Node-RED:
#    Clique nos "..." da aba (Flow) > Edit Flow > aba "Environment
#    Variables" e cadastre lá. Isso só vale para os nós daquela aba.
#
# OBS: HOST_NODERED_LOCAL, HOST_NODERED_LOCAL_ALT e HOST_LOCAL_KANBAN
# apontam pro MESMO Node-RED (self-calls), só que escritos de 3 formas
# diferentes no código original (por IP, por localhost:1880 e por
# localhost puro). Mantive os 3 separados pra não mudar nada no
# comportamento atual, mas se quiser posso unificar tudo numa única
# variável (ex: HOST_NODERED_LOCAL=http://localhost:1880) — é mais
# limpo e evita esse tipo de inconsistência no futuro.
